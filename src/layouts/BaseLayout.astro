---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'NAD.KAH Kreativarbeit – Dekorationen & Textilplott aus Feldkirch, Vorarlberg. Persönliche Anfragen willkommen.' } = Astro.props;
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description}>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Josefin+Sans:wght@300;400;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/style.css">
  <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
</head>
<body>
  <slot />
  <script src="/main.js" is:inline></script>
  <script is:inline>
    if (window.netlifyIdentity) {
      window.netlifyIdentity.on("init", function(user) {
        if (!user) {
          window.netlifyIdentity.on("login", function() {
            document.location.href = "/admin/";
          });
        }
      });
      // Automatically open the modal when an invite token is in the URL
      if (window.location.hash && window.location.hash.match(/#invite_token=/)) {
        window.netlifyIdentity.open("invite");
      }
    }
  </script>
</body>
</html>
