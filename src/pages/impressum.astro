  <div class="impressum-page">
    <a href="/" class="detail-back">&larr; Zurück zur Startseite</a>

    <h1 class="impressum-title">Impressum</h1>

    <div class="impressum-section">
      <h2>Angaben gemäß §&nbsp;5 E-Commerce-Gesetz (ECG) und §&nbsp;25 Mediengesetz (MedG)</h2>

      <h3>Medieninhaberin &amp; Herausgeberin</h3>
